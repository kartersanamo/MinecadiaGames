# Copy to .env and fill in your values. Do not commit .env (it is in .gitignore).

# Discord bot token (required to run the bot)
DISCORD_TOKEN=

# MySQL database (used if DB_HOST is set; otherwise config from bot.json is used)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_AUTOCOMMIT=true

# Games bot API secret (for sync API / dashboard)
GAMES_BOT_API_SECRET=

# Management audit log HTTP (XP admin logs)
MANAGEMENT_LOG_API_SECRET=
MANAGEMENT_LOG_HTTP_URL=http://127.0.0.1:8766/api/logs